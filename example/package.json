{
  "name": "@dr.pogodin/react-native-fs-example",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "android:prod": "react-native run-android --mode release",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "windows": "npx @react-native-community/cli run-windows",
    "windows:autolink": "./node_modules/.bin/rnc-cli autolink-windows --sln \"windows\\ReactNativeFsExample.sln\" --proj \"windows\\ReactNativeFsExample\\ReactNativeFsExample.vcxproj\"",
    "build:android": "react-native build-android --extra-params \"--no-daemon --console=plain -PreactNativeArchitectures=arm64-v8a\"",
    "build:ios": "react-native build-ios --mode Debug"
  },
  "dependencies": {
    "@dr.pogodin/react-native-static-server": "^0.27.0",
    "lodash": "^4.18.1",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "^5.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/runtime": "^7.29.7",
    "@react-native-community/cli": "20.1.3",
    "@react-native-community/cli-platform-android": "20.1.3",
    "@react-native-community/cli-platform-ios": "20.1.3",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/jest-preset": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@rnx-kit/jest-preset": "^0.3.2",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.17",
    "react-native-builder-bob": "^0.42.1",
    "react-native-monorepo-config": "^0.3.5"
  },
  "engines": {
    "node": ">=22.11.0"
  },
  "react-native-windows": {
    "init-windows": {
      "name": "ReactNativeFsExample",
      "namespace": "ReactNativeFsExample",
      "template": "cpp-app"
    }
  }
}
